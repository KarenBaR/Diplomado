{
  "swagger": "2.0",
  "info": {
    "title": "API CEM - Interbank NBC Empresas",
    "description": "Calculo de CEM para integracion con Copilot Studio.",
    "version": "3.0.0"
  },
  "host": "localhost:8000",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "definitions": {
    "BuscarRucRequest": {
      "properties": {
        "ruc": {
          "type": "string",
          "maxLength": 11,
          "minLength": 8,
          "title": "Ruc",
          "description": "RUC o DNI del lead"
        }
      },
      "type": "object",
      "required": [
        "ruc"
      ],
      "title": "BuscarRucRequest"
    },
    "CalcularCEMRequest": {
      "properties": {
        "ruc": {
          "type": "string",
          "title": "Ruc",
          "description": "RUC/DNI del lead"
        },
        "oferta_solicitada": {
          "type": "number",
          "minimum": 0.0,
          "exclusiveMinimum": true,
          "title": "Oferta Solicitada",
          "description": "Monto de la oferta en S/"
        },
        "plazo_meses": {
          "type": "integer",
          "minimum": 0.0,
          "exclusiveMinimum": true,
          "title": "Plazo Meses",
          "description": "Plazo en meses"
        },
        "venta_mensual_rp": {
          "type": "number",
          "minimum": 0.0,
          "exclusiveMinimum": true,
          "title": "Venta Mensual Rp",
          "description": "Venta mensual segun RP en S/"
        },
        "gastos_admin_mensual": {
          "type": "number",
          "minimum": 0.0,
          "title": "Gastos Admin Mensual",
          "description": "Gastos admin mensuales aprox en S/"
        },
        "gasto_financiero_mensual": {
          "type": "number",
          "minimum": 0.0,
          "title": "Gasto Financiero Mensual",
          "description": "Gasto financiero mensual (validado por el usuario)"
        }
      },
      "type": "object",
      "required": [
        "ruc",
        "oferta_solicitada",
        "plazo_meses",
        "venta_mensual_rp",
        "gastos_admin_mensual",
        "gasto_financiero_mensual"
      ],
      "title": "CalcularCEMRequest"
    },
    "DatosLeadResponse": {
      "properties": {
        "encontrado": {
          "type": "boolean",
          "title": "Encontrado"
        },
        "ruc": {
          "type": "string",
          "title": "Ruc"
        },
        "razon_social": {
          "type": "string",
          "title": "Razon Social",
          "description": "Razon social del lead",
          "default": ""
        },
        "giro_canonico": {
          "type": "string",
          "title": "Giro Canonico",
          "description": "Giro canonico del lead",
          "default": ""
        },
        "subsector": {
          "type": "string",
          "title": "Subsector",
          "description": "Subsector del lead",
          "default": ""
        },
        "margen_asignado": {
          "type": "number",
          "title": "Margen Asignado",
          "description": "Margen asignado al sector",
          "default": 0.0
        },
        "deuda_total_sbs": {
          "type": "number",
          "title": "Deuda Total Sbs",
          "description": "Deuda total SBS en S/",
          "default": 0.0
        },
        "pago_mensual_financiero": {
          "type": "number",
          "title": "Pago Mensual Financiero",
          "description": "Pago mensual financiero en S/",
          "default": 0.0
        },
        "tiempo_vida_empresa": {
          "type": "number",
          "title": "Tiempo Vida Empresa",
          "description": "Tiempo de vida de la empresa en anios",
          "default": 0.0
        },
        "cant_trabajadores": {
          "type": "string",
          "title": "Cant Trabajadores",
          "description": "Cantidad de trabajadores",
          "default": ""
        },
        "mensaje_copilot": {
          "type": "string",
          "title": "Mensaje Copilot"
        }
      },
      "type": "object",
      "required": [
        "encontrado",
        "ruc",
        "mensaje_copilot"
      ],
      "title": "DatosLeadResponse"
    },
    "DetalleCEMResponse": {
      "properties": {
        "venta_mensual_rp": {
          "type": "number",
          "title": "Venta Mensual Rp"
        },
        "factor_informalidad": {
          "type": "number",
          "title": "Factor Informalidad"
        },
        "paso_01_ventas_rt": {
          "type": "number",
          "title": "Paso 01 Ventas Rt"
        },
        "paso_02_costo_ventas": {
          "type": "number",
          "title": "Paso 02 Costo Ventas"
        },
        "paso_03_utilidad_bruta": {
          "type": "number",
          "title": "Paso 03 Utilidad Bruta"
        },
        "paso_04_gastos_admin": {
          "type": "number",
          "title": "Paso 04 Gastos Admin"
        },
        "paso_05_utilidad_operativa": {
          "type": "number",
          "title": "Paso 05 Utilidad Operativa"
        },
        "paso_06_gastos_financieros": {
          "type": "number",
          "title": "Paso 06 Gastos Financieros"
        },
        "paso_07_utilidad_neta": {
          "type": "number",
          "title": "Paso 07 Utilidad Neta"
        },
        "paso_08_gastos_familiares": {
          "type": "number",
          "title": "Paso 08 Gastos Familiares"
        },
        "paso_09_cem": {
          "type": "number",
          "title": "Paso 09 Cem"
        },
        "margen_usado": {
          "type": "number",
          "title": "Margen Usado"
        },
        "fuente_gastos_financieros": {
          "type": "string",
          "title": "Fuente Gastos Financieros"
        }
      },
      "type": "object",
      "required": [
        "venta_mensual_rp",
        "factor_informalidad",
        "paso_01_ventas_rt",
        "paso_02_costo_ventas",
        "paso_03_utilidad_bruta",
        "paso_04_gastos_admin",
        "paso_05_utilidad_operativa",
        "paso_06_gastos_financieros",
        "paso_07_utilidad_neta",
        "paso_08_gastos_familiares",
        "paso_09_cem",
        "margen_usado",
        "fuente_gastos_financieros"
      ],
      "title": "DetalleCEMResponse"
    },
    "HTTPValidationError": {
      "properties": {
        "detail": {
          "items": {
            "$ref": "#/definitions/ValidationError"
          },
          "type": "array",
          "title": "Detail"
        }
      },
      "type": "object",
      "title": "HTTPValidationError"
    },
    "HealthResponse": {
      "properties": {
        "status": {
          "type": "string",
          "title": "Status",
          "description": "Estado del servicio"
        },
        "api": {
          "type": "string",
          "title": "Api",
          "description": "Nombre de la API"
        },
        "version": {
          "type": "string",
          "title": "Version",
          "description": "Version de la API"
        },
        "timestamp": {
          "type": "string",
          "title": "Timestamp",
          "description": "Timestamp ISO del servidor"
        },
        "bd_cargada": {
          "type": "boolean",
          "title": "Bd Cargada",
          "description": "Si la BD se cargo correctamente"
        },
        "registros_unicos": {
          "type": "integer",
          "title": "Registros Unicos",
          "description": "Cantidad de registros unicos en BD"
        },
        "fuente": {
          "type": "string",
          "title": "Fuente",
          "description": "Nombre del archivo de BD"
        }
      },
      "type": "object",
      "required": [
        "status",
        "api",
        "version",
        "timestamp",
        "bd_cargada",
        "registros_unicos",
        "fuente"
      ],
      "title": "HealthResponse",
      "description": "Respuesta del health check."
    },
    "ResultadoCEMResponse": {
      "properties": {
        "exito": {
          "type": "boolean",
          "title": "Exito"
        },
        "timestamp": {
          "type": "string",
          "title": "Timestamp"
        },
        "ruc": {
          "type": "string",
          "title": "Ruc"
        },
        "razon_social": {
          "type": "string",
          "title": "Razon Social"
        },
        "cem_mensual": {
          "type": "number",
          "title": "Cem Mensual"
        },
        "cuota_estimada_mensual": {
          "type": "number",
          "title": "Cuota Estimada Mensual"
        },
        "cem_suficiente": {
          "type": "boolean",
          "title": "Cem Suficiente"
        },
        "alerta": {
          "type": "string",
          "title": "Alerta"
        },
        "nivel_alerta": {
          "type": "string",
          "title": "Nivel Alerta"
        },
        "recomendacion": {
          "type": "string",
          "title": "Recomendacion"
        },
        "detalle": {
          "$ref": "#/definitions/DetalleCEMResponse"
        },
        "mensaje_copilot": {
          "type": "string",
          "title": "Mensaje Copilot"
        }
      },
      "type": "object",
      "required": [
        "exito",
        "timestamp",
        "ruc",
        "razon_social",
        "cem_mensual",
        "cuota_estimada_mensual",
        "cem_suficiente",
        "alerta",
        "nivel_alerta",
        "recomendacion",
        "detalle",
        "mensaje_copilot"
      ],
      "title": "ResultadoCEMResponse"
    },
    "ValidationError": {
      "properties": {
        "loc": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "title": "Location"
        },
        "msg": {
          "type": "string",
          "title": "Message"
        },
        "type": {
          "type": "string",
          "title": "Error Type"
        },
        "input": {
          "title": "Input",
          "type": "string"
        },
        "ctx": {
          "type": "object",
          "title": "Context"
        }
      },
      "type": "object",
      "required": [
        "loc",
        "msg",
        "type"
      ],
      "title": "ValidationError"
    }
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "operationId": "health_check_api_v1_health_get",
        "summary": "Health Check",
        "description": "Health check para Copilot Studio.",
        "produces": [
          "application/json"
        ],
        "consumes": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "schema": {
              "$ref": "#/definitions/HealthResponse"
            }
          }
        }
      }
    },
    "/api/v1/cem/buscar-ruc": {
      "post": {
        "operationId": "buscar_ruc_api_v1_cem_buscar_ruc_post",
        "summary": "Buscar Ruc",
        "description": "PASO 1: Busca el RUC/DNI del lead en la BD real.\nRetorna datos del lead para que Copilot continue el flujo.",
        "produces": [
          "application/json"
        ],
        "consumes": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/BuscarRucRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "schema": {
              "$ref": "#/definitions/DatosLeadResponse"
            }
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        }
      }
    },
    "/api/v1/cem/calcular": {
      "post": {
        "operationId": "calcular_cem_api_v1_cem_calcular_post",
        "summary": "Calcular Cem",
        "description": "PASO FINAL: Calcula el CEM con todos los inputs del ejecutivo.\nCopilot Studio envia los datos de los pasos 1-6.",
        "produces": [
          "application/json"
        ],
        "consumes": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/CalcularCEMRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "schema": {
              "$ref": "#/definitions/ResultadoCEMResponse"
            }
          },
          "422": {
            "description": "Validation Error",
            "schema": {
              "$ref": "#/definitions/HTTPValidationError"
            }
          }
        }
      }
    }
  }
}